# --- Database ---
MONGO_URI=mongodb+srv://youruser:yourpass@cluster.mongodb.net/mcm-dental

# --- Auth ---
# Generate a long random value, e.g.: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_secret
NODE_ENV=development

# --- CORS ---
# The URL your React frontend runs on. In production this is your real domain.
CLIENT_ORIGIN=http://localhost:5173

# --- Google Calendar (service account) ---
# 1. Create a Google Cloud project, enable the Calendar API.
# 2. Create a Service Account, download its JSON key.
# 3. Share the clinic's Google Calendar (mcmdentalclinic@gmail.com) with the
#    service account's email, with "Make changes to events" permission.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=mcmdentalclinic@gmail.com

# --- One-time admin seed (npm run seed) ---
ADMIN_NAME=Clinic Admin
[email protected]
ADMIN_PASSWORD=change_this_before_seeding
